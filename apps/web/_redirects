# MUON NOI — SPA history routing (no hash)
# Always serve index.html for app routes so share links never die.

# ---- Static files (served directly)
# (These lines are optional because Pages will serve them anyway,
# but keeping them makes intent explicit and prevents accidental rewrites.)
/assets/*        /assets/:splat        200
/manifest.json   /manifest.json        200
/favicon.ico     /favicon.ico          200
/robots.txt      /robots.txt           200
/sitemap.xml     /sitemap.xml          200
/404.html        /404.html             200

# ---- External redirects
/docs            https://docs.muonnoi.org/   302
/help            https://docs.muonnoi.org/   302

# ---- SPA fallback (MUST be last)
/*               /index.html           200
